# Supabase Configuration
# Copy this file to `.env` and replace with your actual values
# Never commit your actual `.env` file to version control!

# Find these in: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# POC Supabase project (hosts Edge Functions including gemini-proxy)
POC_SUPABASE_URL=https://YOUR_POC_PROJECT_ID.supabase.co
POC_SUPABASE_ANON_KEY=your_poc_supabase_anon_key_here

# Note: GEMINI_API_KEY is now stored server-side as a Supabase Edge Function secret.
# Set it via: supabase secrets set GEMINI_API_KEY=your_key_here
